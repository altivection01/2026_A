# =============================================================================
# Copy to .env  (cp .env.example .env)  and fill in.  .env is gitignored.
# The notebooks run END-TO-END with NO keys (all infrastructure is mocked).
# Set ONLY the LLM key below to turn on real agent reasoning.
# =============================================================================

# ---- LLM provider selection: anthropic | azure_openai | openai | groq ----
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6           # routine agent reasoning; use claude-opus-4-8 for hard cases

# ---- Anthropic (default) ----
ANTHROPIC_API_KEY=

# ---- Azure OpenAI (if LLM_PROVIDER=azure_openai) ----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4.1       # your deployment name

# ---- (optional others) ----
OPENAI_API_KEY=
GROQ_API_KEY=

# =============================================================================
# REAL integrations — only needed when you replace the mocked backends.
# Every notebook works without ANY of these.
# =============================================================================

# -- Problem 1: Azure AVD --
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
LOG_ANALYTICS_WORKSPACE_ID=

# -- Problem 2: Tanium --
TANIUM_BASE_URL=https://your-tanium.example.com
TANIUM_API_TOKEN=

# -- Problems 1/2/4: ServiceNow --
SERVICENOW_INSTANCE=https://yourinstance.service-now.com
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# -- Problem 3: CVE data + optional Neo4j GraphRAG backend --
NVD_API_KEY=                          # optional; raises NVD rate limits
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# -- Problem 4: CrowdStrike Falcon (Custom IOC management; scope = IOC Management R/W) --
FALCON_CLIENT_ID=
FALCON_CLIENT_SECRET=
FALCON_BASE_URL=us-1                  # us-1 | us-2 | eu-1 | us-gov-1
